# ---------- Storage (required) ----------
# Upstash Redis REST credentials. Without these the app falls back to an
# in-memory store for local dev only (data is lost on restart).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Payments (required for live settlement + burns) ----------
# Until all three are set, settlement returns "Payouts not configured" instead
# of moving funds.

# Solana RPC endpoint (your Helius mainnet URL)
SOLANA_RPC_URL=

# The SPL token mint address of QST (create it with scripts/create-token.mjs)
TOKEN_MINT=

# Platform wallet secret key as a JSON array of numbers (from solana-keygen).
# This wallet holds bounty funds, pays winners, and burns 20% per bounty.
PLATFORM_WALLET_SECRET=

# ---------- Auto-settlement (optional) ----------
# If set, the Vercel Cron settle endpoint requires this bearer token.
CRON_SECRET=
